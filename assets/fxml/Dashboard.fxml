<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0" styleClass="main-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.DashboardController">
    
    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="top-nav">
        <padding><Insets left="25.0" right="25.0" /></padding>
        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-eyebrow" text="SYSTEM OVERVIEW" />
            <Label styleClass="app-logo-text" text="Naval Blood Donation Archive" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <VBox alignment="CENTER_RIGHT" spacing="2.0" styleClass="clock-container-modern">
            <Label fx:id="currentDateTimeLabel" styleClass="clock-time-large" text="12:00 PM" />
            <Label fx:id="currentDateLabel" styleClass="clock-date-sub" text="Sunday, April 26, 2026" />
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="transparent-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="25.0">
            <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>

            <HBox spacing="15.0">
                <VBox styleClass="kpi-card-modern, kpi-blue" HBox.hgrow="ALWAYS">
                    <Label styleClass="kpi-label" text="Total Bags" />
                    <Label fx:id="totalBagsLabel" styleClass="kpi-value" text="0" />
                    <ProgressBar progress="0.7" styleClass="kpi-progress" />
                </VBox>

                <VBox styleClass="kpi-card-modern, kpi-green" HBox.hgrow="ALWAYS">
                    <Label styleClass="kpi-label" text="Available" />
                    <Label fx:id="availableBagsLabel" styleClass="kpi-value" text="0" />
                    <Label styleClass="kpi-subtext" text="Ready for issuance" />
                </VBox>

                <VBox styleClass="kpi-card-modern, kpi-orange" HBox.hgrow="ALWAYS">
                    <Label styleClass="kpi-label" text="Pending TTI" />
                    <Label fx:id="pendingTtiLabel" styleClass="kpi-value" text="0" />
                    <Label styleClass="kpi-subtext" text="Awaiting screening" />
                </VBox>

                <VBox styleClass="kpi-card-modern, kpi-teal" HBox.hgrow="ALWAYS">
                    <Label styleClass="kpi-label" text="Total Donors" />
                    <Label fx:id="totalDonorsLabel" styleClass="kpi-value" text="0" />
                    <Label styleClass="kpi-subtext" text="Active donors" />
                </VBox>
            </HBox>

            <HBox spacing="20.0" prefHeight="350.0">
                <VBox styleClass="glass-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title-modern" text="Blood Stock by Type" />
                    <BarChart fx:id="stockChart" animated="false" styleClass="modern-chart" VBox.vgrow="ALWAYS">
                        <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                        <yAxis><NumberAxis side="LEFT" /></yAxis>
                    </BarChart>
                </VBox>

                <VBox styleClass="glass-card" prefWidth="350.0">
                    <Label styleClass="card-title-modern" text="Inventory Distribution" />
                    <PieChart fx:id="distributionChart" legendSide="BOTTOM" styleClass="modern-chart" VBox.vgrow="ALWAYS" />
                </VBox>
            </HBox>

            <VBox styleClass="glass-card" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label styleClass="card-title-modern" text="Recent System Activity" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="activityCountLabel" styleClass="status-pill-info" text="0 entries today" />
                </HBox>
                <VBox fx:id="activityList" spacing="10.0" styleClass="activity-feed">
                    <padding><Insets top="15.0" /></padding>
                    </VBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>