<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0" styleClass="main-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.RecordsViewController">
    
    <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15.0" styleClass="top-nav">
        <padding><Insets left="20.0" right="20.0" /></padding>
        <VBox spacing="1.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-eyebrow" text="RECORDS MANAGEMENT" />
            <Label styleClass="app-logo-text" text="Masterlists and History" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox spacing="8.0">
            <Button fx:id="refreshButton" onAction="#refreshAll" styleClass="button-secondary" text="Refresh Data" />
            <Button fx:id="editDonorButton" onAction="#editSelectedDonor" styleClass="button-primary" text="Edit Selected Record" />
        </HBox>
    </HBox>

    <VBox spacing="15.0" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /></padding>
        
        <TabPane side="TOP" tabClosingPolicy="UNAVAILABLE" styleClass="modern-tab-pane" VBox.vgrow="ALWAYS">
            <tabs>
                <Tab text="Donors Directory">
                    <VBox spacing="10.0" styleClass="glass-card-no-padding">
                        <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <TextField fx:id="donorSearchField" prefWidth="300.0" promptText="Search by name, ID, or contact..." styleClass="modern-search-field" />
                            <Button onAction="#searchDonors" styleClass="button-primary-small" text="Search" />
                        </HBox>
                        <TableView fx:id="donorTable" onMouseClicked="#onDonorDoubleClick" styleClass="modern-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="donorIdColumn" prefWidth="60.0" text="ID" />
                                <TableColumn fx:id="donorNameColumn" prefWidth="180.0" text="Donor Name" />
                                <TableColumn fx:id="donorSexColumn" prefWidth="70.0" text="Sex" />
                                <TableColumn fx:id="donorBloodTypeColumn" prefWidth="80.0" text="Type" />
                                <TableColumn fx:id="donorContactColumn" prefWidth="130.0" text="Contact" />
                                <TableColumn fx:id="donorLastDonationColumn" prefWidth="130.0" text="Last Donation" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER" styleClass="pagination-container">
                            <Pagination fx:id="donorPagination" maxPageIndicatorCount="5" styleClass="modern-pagination" />
                        </HBox>
                    </VBox>
                </Tab>

                <Tab text="Screening History">
                    <VBox spacing="10.0" styleClass="glass-card-no-padding">
                        <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <TextField fx:id="screeningSearchField" prefWidth="300.0" promptText="Search donor screening records..." styleClass="modern-search-field" />
                            <Button onAction="#searchScreenings" styleClass="button-primary-small" text="Search" />
                        </HBox>
                        <TableView fx:id="screeningTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="screeningIdColumn" text="ID" />
                                <TableColumn fx:id="screeningDonorColumn" text="Donor" />
                                <TableColumn fx:id="screeningDateColumn" text="Date" />
                                <TableColumn fx:id="screeningCollectionColumn" text="Collection" />
                                <TableColumn fx:id="screeningStatusColumn" text="Status" />
                                <TableColumn fx:id="screeningByColumn" text="Handled By" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER" styleClass="pagination-container">
                            <Pagination fx:id="screeningPagination" maxPageIndicatorCount="5" styleClass="modern-pagination" />
                        </HBox>
                    </VBox>
                </Tab>

                <Tab text="Issuance History">
                    <VBox spacing="10.0" styleClass="glass-card-no-padding">
                        <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <TextField fx:id="issuanceSearchField" prefWidth="300.0" promptText="Search issuance records..." styleClass="modern-search-field" />
                            <Button onAction="#searchIssuances" styleClass="button-primary-small" text="Search" />
                        </HBox>
                        <TableView fx:id="issuanceTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="issuanceBagColumn" text="Bag ID" />
                                <TableColumn fx:id="issuancePatientColumn" text="Patient" />
                                <TableColumn fx:id="issuanceHospitalColumn" text="Hospital" />
                                <TableColumn fx:id="issuanceRequestColumn" text="Request #" />
                                <TableColumn fx:id="issuanceCrossmatchColumn" text="Crossmatch" />
                                <TableColumn fx:id="issuanceByColumn" text="Issued By" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER" styleClass="pagination-container">
                            <Pagination fx:id="issuancePagination" maxPageIndicatorCount="5" styleClass="modern-pagination" />
                        </HBox>
                    </VBox>
                </Tab>

                <Tab fx:id="auditTab" text="System Audit">
                    <VBox spacing="10.0" styleClass="glass-card-no-padding">
                        <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                        <TableView fx:id="auditTable" styleClass="modern-table-audit" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="auditTimeColumn" text="Timestamp" />
                                <TableColumn fx:id="auditActorColumn" text="User" />
                                <TableColumn fx:id="auditActionColumn" text="Action" />
                                <TableColumn fx:id="auditEntityColumn" text="Entity" />
                                <TableColumn fx:id="auditDetailsColumn" text="Details" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER" styleClass="pagination-container">
                            <Pagination fx:id="auditPagination" maxPageIndicatorCount="5" styleClass="modern-pagination" />
                        </HBox>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </VBox>
</VBox>