<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0" styleClass="main-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.RecordsViewController">
    
    <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" styleClass="top-nav">
        <padding><Insets left="40.0" right="40.0" /></padding>
        <VBox alignment="CENTER_LEFT" spacing="2.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-eyebrow" text="RECORDS ARCHIVE" />
            <Label styleClass="app-logo-text" text="Masterlists and History" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox spacing="10.0">
            <Button fx:id="refreshButton" onAction="#refreshAll" styleClass="button-secondary" text="Sync Records" />
            <Button fx:id="editDonorButton" onAction="#editSelectedDonor" styleClass="button-primary" text="Modify Selected Record" />
        </HBox>
    </HBox>

    <VBox spacing="25.0" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
        
        <TabPane side="TOP" styleClass="modern-tab-pane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>
                <Tab text="Donors Directory">
                    <VBox spacing="15.0" styleClass="glass-card-no-padding">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                             <TextField fx:id="donorSearchField" prefWidth="350.0" promptText="Search by name, ID, or contact..." styleClass="modern-search-field" />
                             <Button onAction="#searchDonors" styleClass="button-primary-small" text="Search" />
                             <Button onAction="#exportDonorsToCsv" styleClass="button-secondary" text="Export CSV" />
                             <Region HBox.hgrow="ALWAYS" />
                             <TextField fx:id="staffSearchField" prefWidth="250.0" promptText="Filter by handled staff..." styleClass="modern-search-field" />
                             <Button onAction="#searchDonorsByStaff" styleClass="button-primary-small" text="By Staff" />
                         </HBox>
                        
                        <TableView fx:id="donorTable" onMouseClicked="#onDonorDoubleClick" styleClass="modern-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="donorIdColumn" prefWidth="80.0" text="Donor ID" />
                                <TableColumn fx:id="donorNameColumn" prefWidth="250.0" text="Donor Full Name" />
                                <TableColumn fx:id="donorSexColumn" prefWidth="80.0" text="Sex" />
                                <TableColumn fx:id="donorBloodTypeColumn" prefWidth="100.0" text="Blood Type" />
                                <TableColumn fx:id="donorContactColumn" prefWidth="150.0" text="Primary Contact" />
                                <TableColumn fx:id="donorLastDonationColumn" prefWidth="180.0" text="Last Donation Date" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        
                        <HBox alignment="CENTER" styleClass="pagination-container">
                            <Pagination fx:id="donorPagination" maxPageIndicatorCount="5" styleClass="modern-pagination" />
                        </HBox>
                    </VBox>
                </Tab>

                <Tab text="Screening History">
                    <VBox spacing="15.0" styleClass="glass-card-no-padding">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                             <TextField fx:id="screeningSearchField" prefWidth="350.0" promptText="Search donor screening records..." styleClass="modern-search-field" />
                             <Button onAction="#searchScreenings" styleClass="button-primary-small" text="Search History" />
                             <Button onAction="#exportScreeningToCsv" styleClass="button-secondary" text="Export CSV" />
                         </HBox>
                        
                        <TableView fx:id="screeningTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="screeningIdColumn" prefWidth="100.0" text="Record ID" />
                                <TableColumn fx:id="screeningDonorColumn" prefWidth="200.0" text="Donor Name" />
                                <TableColumn fx:id="screeningDateColumn" prefWidth="150.0" text="Screening Date" />
                                <TableColumn fx:id="screeningCollectionColumn" prefWidth="150.0" text="Collection Status" />
                                <TableColumn fx:id="screeningStatusColumn" prefWidth="120.0" text="Result" />
                                <TableColumn fx:id="screeningByColumn" prefWidth="150.0" text="Assigned Staff" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        
                        <HBox alignment="CENTER" styleClass="pagination-container">
                            <Pagination fx:id="screeningPagination" maxPageIndicatorCount="5" styleClass="modern-pagination" />
                        </HBox>
                    </VBox>
                </Tab>

                <Tab text="Issuance History">
                    <VBox spacing="15.0" styleClass="glass-card-no-padding">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                             <TextField fx:id="issuanceSearchField" prefWidth="350.0" promptText="Search issuance records..." styleClass="modern-search-field" />
                             <Button onAction="#searchIssuances" styleClass="button-primary-small" text="Search Issuance" />
                             <Button onAction="#exportIssuanceToCsv" styleClass="button-secondary" text="Export CSV" />
                         </HBox>
                        
                        <TableView fx:id="issuanceTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="issuanceBagColumn" prefWidth="120.0" text="Bag ID" />
                                <TableColumn fx:id="issuancePatientColumn" prefWidth="200.0" text="Patient Name" />
                                <TableColumn fx:id="issuanceHospitalColumn" prefWidth="200.0" text="Hospital / Clinic" />
                                <TableColumn fx:id="issuanceRequestColumn" prefWidth="150.0" text="Request #" />
                                <TableColumn fx:id="issuanceCrossmatchColumn" prefWidth="150.0" text="Crossmatch Status" />
                                <TableColumn fx:id="issuanceByColumn" prefWidth="150.0" text="Issued By" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        
                        <HBox alignment="CENTER" styleClass="pagination-container">
                            <Pagination fx:id="issuancePagination" maxPageIndicatorCount="5" styleClass="modern-pagination" />
                        </HBox>
                    </VBox>
                </Tab>

                <Tab fx:id="auditTab" text="System Audit">
                     <VBox spacing="15.0" styleClass="glass-card-no-padding">
                         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                         <HBox alignment="CENTER_LEFT" spacing="15.0">
                             <TextField fx:id="auditSearchField" prefWidth="350.0" promptText="Search audit logs..." styleClass="modern-search-field" />
                             <Button onAction="#searchAudits" styleClass="button-primary-small" text="Filter Logs" />
                             <Button onAction="#exportAuditToCsv" styleClass="button-secondary" text="Export CSV" />
                         </HBox>
                         
                         <TableView fx:id="auditTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="auditTimeColumn" prefWidth="180.0" text="Event Timestamp" />
                                <TableColumn fx:id="auditActorColumn" prefWidth="150.0" text="Authorized User" />
                                <TableColumn fx:id="auditActionColumn" prefWidth="120.0" text="Action Type" />
                                <TableColumn fx:id="auditEntityColumn" prefWidth="150.0" text="Affected Entity" />
                                <TableColumn fx:id="auditDetailsColumn" prefWidth="300.0" text="Event Details" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                        
                        <HBox alignment="CENTER" styleClass="pagination-container">
                            <Pagination fx:id="auditPagination" maxPageIndicatorCount="5" styleClass="modern-pagination" />
                        </HBox>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </VBox>
</VBox>