<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0" styleClass="main-container" stylesheets="@../css/um.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.UserManagementController">
    
    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="top-nav">
        <padding><Insets left="25.0" right="25.0" /></padding>
        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-eyebrow" text="ADMINISTRATION" />
            <Label styleClass="app-logo-text" text="Staff &amp; User Accounts" />
        </VBox>
        <HBox alignment="CENTER" spacing="12.0">
            <TextField fx:id="searchUserField" prefWidth="250.0" promptText="Search staff by name or ID..." styleClass="modern-search-field" />
            <Button fx:id="addUserButton" onAction="#showAddUserDialog" styleClass="button-primary" text="+ Add New Staff" />
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="transparent-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="25.0">
            <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>

            <HBox spacing="20.0">
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="glass-card-compact" HBox.hgrow="ALWAYS">
                    <StackPane styleClass="icon-circle-blue">
                        <Label styleClass="icon-text-small" text="👤" />
                    </StackPane>
                    <VBox>
                        <Label styleClass="card-subtitle-muted" text="Active Staff" />
                        <Label fx:id="activeUsersCount" styleClass="card-value-small" text="0" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="glass-card-compact" HBox.hgrow="ALWAYS">
                    <StackPane styleClass="icon-circle-orange">
                        <Label styleClass="icon-text-small" text="🔒" />
                    </StackPane>
                    <VBox>
                        <Label styleClass="card-subtitle-muted" text="Admin Access" />
                        <Label fx:id="adminCount" styleClass="card-value-small" text="0" />
                    </VBox>
                </HBox>
            </HBox>

            <VBox spacing="15.0" styleClass="glass-card-no-padding" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="card-title-modern" text="Personnel Directory" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="refreshButton" onAction="#refreshUsers" styleClass="btn-mini-outline" text="Refresh List" />
                </HBox>

                <TableView fx:id="usersTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="staffIdCol" prefWidth="120.0" text="Staff ID" />
                        <TableColumn fx:id="nameCol" prefWidth="200.0" text="Full Name" />
                        <TableColumn fx:id="usernameCol" prefWidth="150.0" text="Username" />
                        <TableColumn fx:id="roleCol" prefWidth="120.0" text="System Role" />
                        <TableColumn fx:id="statusCol" prefWidth="120.0" text="Account Status" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </ScrollPane>

</VBox>
