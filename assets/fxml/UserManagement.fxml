<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0" styleClass="main-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.UserManagementController">
    
    <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" styleClass="top-nav">
        <padding><Insets left="40.0" right="40.0" /></padding>
        <VBox alignment="CENTER_LEFT" spacing="2.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-eyebrow" text="ADMINISTRATION" />
            <Label styleClass="app-logo-text" text="Personnel &amp; User Accounts" />
        </VBox>
        <HBox alignment="CENTER" spacing="12.0">
            <TextField fx:id="searchUserField" prefWidth="300.0" promptText="Search personnel by name or ID..." styleClass="modern-search-field" />
            <Button fx:id="addUserButton" onAction="#showAddUserDialog" prefHeight="45.0" styleClass="button-primary" text="+ Add New Staff" />
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="content-scroll-pane" VBox.vgrow="ALWAYS">
        <VBox spacing="35.0">
            <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>

            <HBox spacing="30.0">
                <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                    <VBox spacing="4.0">
                        <Label styleClass="kpi-label" text="ACTIVE PERSONNEL" />
                        <Label fx:id="activeUsersCount" styleClass="kpi-value" text="0" />
                        <Label styleClass="kpi-subtext" text="Staff with system access" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                    <VBox spacing="4.0">
                        <Label styleClass="kpi-label" text="ADMINISTRATORS" />
                        <Label fx:id="adminCount" styleClass="kpi-value" text="0" />
                        <Label styleClass="kpi-subtext" text="Privileged system access" />
                    </VBox>
                </HBox>
            </HBox>

            <VBox spacing="20.0" styleClass="glass-card-no-padding" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="card-title" text="Personnel Directory" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="refreshButton" onAction="#refreshUsers" styleClass="button-secondary" text="Sync Personnel List" />
                </HBox>
                <Separator />

                <TableView fx:id="usersTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="staffIdCol" prefWidth="120.0" text="Staff ID" />
                        <TableColumn fx:id="nameCol" prefWidth="250.0" text="Full Legal Name" />
                        <TableColumn fx:id="usernameCol" prefWidth="150.0" text="System Username" />
                        <TableColumn fx:id="roleCol" prefWidth="150.0" text="Assigned Role" />
                        <TableColumn fx:id="statusCol" prefWidth="120.0" text="Access Status" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
