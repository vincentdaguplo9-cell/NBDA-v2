<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0" styleClass="main-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.RecordDonationController">
    
    <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" styleClass="top-nav">
        <padding><Insets left="40.0" right="40.0" /></padding>
        <VBox alignment="CENTER_LEFT" spacing="2.0">
            <Label styleClass="page-eyebrow" text="BLOOD SERVICES" />
            <Label styleClass="app-logo-text" text="Record Return Donation" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#clearForm" styleClass="button-secondary" text="Reset Form" />
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="content-scroll-pane" VBox.vgrow="ALWAYS">
        <VBox spacing="35.0">
            <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>

            <HBox spacing="30.0">
                <!-- Donor Lookup Section -->
                <VBox spacing="25.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                    <VBox spacing="6.0">
                        <Label styleClass="card-title" text="Find Returning Donor" />
                        <Label styleClass="card-subtitle" text="Search by name or contact number" />
                    </VBox>
                    <Separator />

                    <VBox spacing="20.0">
                        <HBox spacing="15.0" alignment="BOTTOM_LEFT">
                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Donor Search Criteria" />
                                <TextField fx:id="searchField" promptText="Enter Donor ID or Name..." styleClass="modern-input" />
                            </VBox>
                            <Button fx:id="searchButton" onAction="#searchDonor" prefHeight="45.0" styleClass="button-primary-small" text="Lookup Donor" />
                        </HBox>

                        <VBox fx:id="donorInfoBox" spacing="8.0" styleClass="status-container-active">
                            <Label fx:id="donorInfoLabel" styleClass="status-text-bold" text="Awaiting system search..." />
                            <Label fx:id="eligibilityStatusLabel" styleClass="status-text-light" text="Search for a donor to see eligibility details" />
                        </VBox>

                        <VBox spacing="10.0">
                            <Label styleClass="sidebar-section-header" text="DONOR INFORMATION (READ-ONLY)" />
                            <Separator />
                        </VBox>

                        <GridPane hgap="20.0" vgap="20.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                            </columnConstraints>
                            
                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label styleClass="field-label" text="Last Name" />
                                <TextField fx:id="lastNameField" editable="false" styleClass="modern-input" />
                            </VBox>
                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label styleClass="field-label" text="First Name" />
                                <TextField fx:id="firstNameField" editable="false" styleClass="modern-input" />
                            </VBox>
                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label styleClass="field-label" text="Blood Type" />
                                <ComboBox fx:id="bloodTypeCombo" disable="true" maxWidth="Infinity" styleClass="modern-combo" />
                            </VBox>
                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label styleClass="field-label" text="Barangay" />
                                <ComboBox fx:id="barangayCombo" disable="true" maxWidth="Infinity" styleClass="modern-combo" />
                            </VBox>
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- Medical Screening Section -->
                <VBox spacing="25.0" styleClass="glass-card" prefWidth="480.0">
                    <VBox spacing="6.0">
                        <Label styleClass="card-title" text="Medical Update" />
                        <Label styleClass="card-subtitle" text="Vitals for today's collection" />
                    </VBox>
                    <Separator />

                    <GridPane hgap="20.0" vgap="20.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                            <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                        </columnConstraints>

                        <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="0">
                            <Label styleClass="field-label" text="Collection Date *" />
                            <DatePicker fx:id="collectionDatePicker" maxWidth="Infinity" styleClass="modern-datepicker" />
                        </VBox>

                        <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label styleClass="field-label" text="Weight (kg) *" />
                            <TextField fx:id="weightField" promptText="50" styleClass="modern-input" />
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label styleClass="field-label" text="BP (sys/dia) *" />
                            <TextField fx:id="bpField" promptText="120/80" styleClass="modern-input" />
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label styleClass="field-label" text="Pulse (bpm) *" />
                            <TextField fx:id="pulseField" promptText="72" styleClass="modern-input" />
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <Label styleClass="field-label" text="Temp (C) *" />
                            <TextField fx:id="temperatureField" promptText="36.8" styleClass="modern-input" />
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="3">
                            <Label styleClass="field-label" text="Hemog (g/dL) *" />
                            <TextField fx:id="hemoglobinField" promptText="13.5" styleClass="modern-input" />
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <Label styleClass="field-label" text="Vol (mL) *" />
                            <TextField fx:id="volumeField" promptText="450" styleClass="modern-input" />
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4">
                            <Label styleClass="field-label" text="Sleep Hours *" />
                            <TextField fx:id="sleptHoursField" promptText="8" styleClass="modern-input" />
                        </VBox>
                    </GridPane>

                    <Region VBox.vgrow="ALWAYS" />

                    <VBox spacing="10.0">
                        <Label styleClass="field-label" text="Eligibility Validation" />
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="status-container-active">
                            <Circle fill="#f59e0b" radius="6.0" />
                            <VBox spacing="2.0">
                                <Label fx:id="waitTimeValueLabel" styleClass="status-text-bold" text="Awaiting Search" />
                                <Label fx:id="waitTimeHintLabel" styleClass="status-text-light" text="Search for a donor to verify eligibility" />
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>

            <!-- Footer Section -->
            <HBox alignment="CENTER_LEFT" spacing="30.0" styleClass="glass-card-footer">
                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="card-title-small" text="Safety Readiness Checklist" />
                    <FlowPane hgap="30.0" vgap="15.0">
                        <CheckBox fx:id="hadMealCheckBox" text="Has eaten today" />
                        <CheckBox fx:id="alcoholCheckBox" text="No alcohol (24h)" />
                        <CheckBox fx:id="feverCheckBox" text="No fever/cold" />
                        <CheckBox fx:id="tattooCheckBox" text="No tattoo (12m)" />
                    </FlowPane>
                </VBox>
                
                <Separator orientation="VERTICAL" />

                <VBox alignment="CENTER_RIGHT" spacing="12.0" minWidth="320.0">
                    <Label fx:id="resultLabel" styleClass="feedback-text" text="Find donor to begin recording..." wrapText="true" alignment="CENTER_RIGHT" />
                    <HBox alignment="CENTER_RIGHT" spacing="20.0">
                        <Label fx:id="eligibilityStatusLabel2" styleClass="status-pill" text="Verify" />
                        <Button fx:id="saveButton" onAction="#recordDonation" prefHeight="55.0" prefWidth="240.0" styleClass="button-primary" text="Confirm &amp; Record Return" />
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>