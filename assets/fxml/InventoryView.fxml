<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0" styleClass="main-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.InventoryViewController">
    
    <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" styleClass="top-nav">
        <padding><Insets left="40.0" right="40.0" /></padding>
        <VBox alignment="CENTER_LEFT" spacing="2.0">
            <Label styleClass="page-eyebrow" text="BLOOD INVENTORY" />
            <Label styleClass="app-logo-text" text="Archive Management" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER" spacing="10.0">
             <Button fx:id="refreshButton" onAction="#refreshInventory" styleClass="button-secondary" text="Sync Data" />
             <Button fx:id="exportCsvButton" onAction="#exportToCsv" styleClass="button-secondary" text="Export CSV" />
             <Button fx:id="releaseIssueButton" onAction="#handleReleaseOrIssue" styleClass="button-primary" text="Screen / Issue Bag" />
        </HBox>
    </HBox>

    <VBox spacing="25.0" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
        
        <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="glass-card">
            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Search Archive" />
                <HBox spacing="10.0">
                    <TextField fx:id="searchField" promptText="Search Bag ID, Donor, or Barangay..." styleClass="modern-input" HBox.hgrow="ALWAYS" />
                    <Button fx:id="searchButton" onAction="#searchInventory" styleClass="button-primary-small" text="Search" />
                </HBox>
            </VBox>
            <Separator orientation="VERTICAL" />
            <VBox spacing="8.0">
                <Label styleClass="field-label" text="Filters" />
                <HBox spacing="10.0">
                    <ComboBox fx:id="bloodTypeFilterCombo" prefWidth="100.0" promptText="Type" styleClass="modern-combo" />
                    <ComboBox fx:id="barangayFilterCombo" prefWidth="150.0" promptText="Barangay" styleClass="modern-combo" />
                    <ComboBox fx:id="statusFilterCombo" prefWidth="120.0" promptText="Status" styleClass="modern-combo" />
                    <Button fx:id="clearFilterButton" onAction="#clearFilters" styleClass="button-secondary" text="Clear" />
                </HBox>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT" spacing="5.0">
                <Label styleClass="field-label" text="Page Summary" />
                <Label fx:id="pageSummaryLabel" styleClass="status-pill" text="Showing 0 of 0 units" />
            </VBox>
        </HBox>

        <VBox spacing="15.0" styleClass="glass-card-no-padding" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
            <TableView fx:id="inventoryTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="bagIdColumn" prefWidth="100.0" text="Bag ID" />
                    <TableColumn fx:id="bloodTypeColumn" prefWidth="80.0" text="Type" />
                    <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
                    <TableColumn fx:id="collectedColumn" prefWidth="120.0" text="Collected" />
                    <TableColumn fx:id="expiryColumn" prefWidth="120.0" text="Expiry" />
                    <TableColumn fx:id="donorColumn" prefWidth="180.0" text="Donor" />
                    <TableColumn fx:id="barangayColumn" prefWidth="130.0" text="Barangay" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER" styleClass="pagination-container">
                <Pagination fx:id="inventoryPagination" maxPageIndicatorCount="6" styleClass="modern-pagination" />
            </HBox>
        </VBox>
    </VBox>
</VBox>