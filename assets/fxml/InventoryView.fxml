<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0" styleClass="main-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.InventoryViewController">
    
    <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10.0" styleClass="top-nav">
        <padding><Insets left="15.0" right="15.0" /></padding>
        <VBox spacing="1.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-eyebrow" text="ARCHIVE" />
            <Label styleClass="app-logo-text" text="Blood Inventory" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER" spacing="5.0">
            <TextField fx:id="searchField" prefWidth="180.0" promptText="Search bag ID or donor..." styleClass="modern-search-field" />
            <Button fx:id="searchButton" onAction="#searchInventory" styleClass="button-primary-small" text="Search" />
            <Button fx:id="refreshButton" onAction="#refreshInventory" styleClass="button-secondary" text="Refresh" />
            <Button fx:id="releaseIssueButton" onAction="#handleReleaseOrIssue" styleClass="button-primary" text="Screen / Issue" />
        </HBox>
    </HBox>

    <VBox spacing="10.0" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>

        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="glass-card-compact">
            <Label styleClass="field-label-bold" text="Quick Filters:" />
            
            <ComboBox fx:id="bloodTypeFilterCombo" prefWidth="80.0" promptText="Type" styleClass="modern-combo" />
            
            <ComboBox fx:id="barangayFilterCombo" prefWidth="120.0" promptText="Barangay" styleClass="modern-combo" />
            
            <ComboBox fx:id="statusFilterCombo" prefWidth="100.0" promptText="Status" styleClass="modern-combo" />

            <Button fx:id="clearFilterButton" onAction="#clearFilters" styleClass="btn-mini-outline" text="Clear All Filters" />
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox alignment="CENTER" spacing="8.0" styleClass="status-pill-info">
                <Circle fill="#3498db" radius="4.0" />
                <Label fx:id="pageSummaryLabel" styleClass="info-text-sub" text="Showing 0-0 of 0 units" />
            </HBox>
        </HBox>

        <VBox spacing="10.0" styleClass="glass-card-no-padding" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
            
            <TableView fx:id="inventoryTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="bagIdColumn" prefWidth="100.0" text="Bag ID" />
                    <TableColumn fx:id="bloodTypeColumn" prefWidth="80.0" text="Type" />
                    <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
                    <TableColumn fx:id="collectedColumn" prefWidth="120.0" text="Collected" />
                    <TableColumn fx:id="expiryColumn" prefWidth="120.0" text="Expiry" />
                    <TableColumn fx:id="donorColumn" prefWidth="180.0" text="Donor" />
                    <TableColumn fx:id="barangayColumn" prefWidth="130.0" text="Barangay" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER" styleClass="pagination-container">
                <Pagination fx:id="inventoryPagination" maxPageIndicatorCount="6" styleClass="modern-pagination" />
            </HBox>
        </VBox>
    </VBox>
</VBox>